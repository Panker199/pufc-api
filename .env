# ─── Pak United FC API — Environment Variables ───────────
# Copy this to .env for local dev
# On Railway: set these in the "Variables" tab

# ── Database ──────────────────────────────────────────────
# Full Render PostgreSQL connection string (from Render dashboard)
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=postgresql://pufc_user:i8W5tP2Kl4MvjdqCasPNReZHdczrspjM@dpg-d6tuv2fafjfc73fpna50-a.oregon-postgres.render.com/pufc?uselibpqcompat=true&sslmode=require

# ── App ───────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── JWT ───────────────────────────────────────────────────
# Change this to a long random string in production!
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=pufc_pak_united_2024_K9mXvRtL2qBsNwPzY7jE3cFhA5dGiO

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Use * to allow all (not recommended for production)
# Add your Blogger URL here
ALLOWED_ORIGINS=https://pakunitedfc.blogspot.com,http://localhost:3000

# ── Email (optional — for password reset emails) ──────────
# Use a Gmail App Password (NOT your real Gmail password)
